{
  "name": "geometry-of-poker",
  "version": "0.1.0",
  "private": true,
  "description": "Research-grade interactive 3D visualization of Texas Hold'em state space",
  "scripts": {
    "dev": "pnpm --filter @geometry-of-poker/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "generate": "pnpm --filter @geometry-of-poker/dataset-generator generate",
    "generate:all": "pnpm generate -- --all --seed 42 --mode compact",
    "pipeline:extract": "pnpm --filter @geometry-of-poker/feature-engine extract",
    "pipeline:generate": "pnpm generate -- --all --seed 42 --mode compact",
    "pipeline:embed": "cd pipeline && python -m embed.run --all",
    "release:artifacts": "pnpm --filter @geometry-of-poker/web sync-artifacts",
    "validate:artifacts": "node scripts/validate-release-artifacts.mjs",
    "aws:deploy-artifacts": "node deploy/aws/deploy-artifact-stack.mjs",
    "aws:build-worker": "node deploy/aws/build-worker-in-codebuild.mjs",
    "aws:push-worker": "node deploy/aws/build-push-release-worker.mjs",
    "aws:submit-release": "node deploy/aws/submit-release-job.mjs",
    "benchmark": "node scripts/benchmark-performance.mjs"
  },
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
